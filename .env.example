# ideaRound 环境变量配置

# ==================== 数据库配置 ====================
# 请根据你的本地 MySQL 配置修改下面的用户名和密码
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
#DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/idearound?charset=utf8mb4
DATABASE_URL=sqlite+aiosqlite:///./idearound.db

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=15001
SERVER_RELOAD=true

# ==================== 认证配置 ====================
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
AUTH_ENABLED=true
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== 管理员配置 ====================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ==================== CORS 配置 ====================
# 允许的源地址，多个用逗号分隔，* 表示允许所有
CORS_ORIGINS=*

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 提示词配置 ====================
PROMPT_BASE_PATH=configs/prompts

# ==================== 数据库连接池配置 (仅 MySQL) ====================
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# ==================== Redis 配置 ====================
# 启用 Redis 可获得：跨 Worker SSE 推送、消息摘要缓存、任务状态缓存
# 如需启用，填写 REDIS_HOST 即可自动激活；留空则降级为进程内存缓存（仅适用单 Worker）
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# ==================== 其他配置 ====================
TZ=Asia/Shanghai
