# ideaRound 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# ==================== 数据库配置 ====================
# MySQL 配置（生产环境推荐）
# DATABASE_URL=mysql+aiomysql://idearound:your-password@localhost:3306/idearound?charset=utf8mb4

# SQLite 配置（开发环境使用）
DATABASE_URL=sqlite+aiosqlite:///./idearound.db

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=15001
SERVER_RELOAD=true

# ==================== 认证配置 ====================
# JWT 密钥（生产环境必须修改！建议使用：openssl rand -hex 32）
JWT_SECRET_KEY=your-production-secret-key-min-32-characters-long

# JWT 算法
JWT_ALGORITHM=HS256

# 是否启用登录认证（true/false）
AUTH_ENABLED=true

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 刷新 Token 过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== 管理员配置 ====================
# 初始管理员账号（首次启动后建议修改密码）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password-immediately

# ==================== 提示词配置 ====================
PROMPT_BASE_PATH=configs/prompts

# ==================== 其他配置 ====================
# 时区
TZ=Asia/Shanghai
